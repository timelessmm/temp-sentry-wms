{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentry-wms.example/events/ship.voided/1.json",
  "title": "ship.voided v1",
  "description": "A previously-shipped sales order has been voided. Emitted by api/routes/dockd.py::void_ship. Aggregate: sales_order.",
  "type": "object",
  "required": [
    "sales_order_external_id",
    "voided_at",
    "voided_by_user_external_id",
    "reason",
    "reverted_to_status"
  ],
  "additionalProperties": false,
  "properties": {
    "sales_order_external_id": { "type": "string", "format": "uuid" },
    "voided_at": { "type": "string", "format": "date-time" },
    "voided_by_user_external_id": { "type": "string", "format": "uuid" },
    "reason": { "type": "string" },
    "reverted_to_status": { "type": "string", "enum": ["PICKED", "PACKED"] }
  }
}
