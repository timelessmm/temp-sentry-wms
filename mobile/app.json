{
  "expo": {
    "name": "Sentry WMS",
    "slug": "sentry-wms",
    "version": "1.9.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hightowersystems.sentrywms"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.hightowersystems.sentrywms",
      "versionCode": 6,
      "usesCleartextTraffic": true,
      "permissions": [
        "INTERNET",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      "expo-splash-screen",
      "./plugins/chainway-scanner",
      "./plugins/with-cleartext-traffic"
    ],
    "extra": {
      "eas": {
        "projectId": "8df87216-03e6-4715-acbc-33f9fd23582d"
      }
    },
    "owner": "mhightower932"
  }
}
